# Script backups — do not commit (real code lives at repo root)
_bak_submodule_fix_*/

# Never commit archives (GitHub rejects >100MB; slow push)
*.zip
*.7z
*.rar
*.tar
*.tar.gz
*.tgz

# Dependencies / build (any subfolder)
**/node_modules/

# Env & secrets
.env
.env.*
!.env.example
**/secrets/
**/*firebase-adminsdk*.json

# Logs & OS
*.log
.DS_Store
Thumbs.db

# Next.js build (if tracked from monorepo root)
**/.next/
**/out/
