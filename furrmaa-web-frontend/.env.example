# =============================================================================
# COPY TO `.env` — yehi structure `.env` me honi chahiye (values apni bharo)
# =============================================================================

NEXT_PUBLIC_API_URL=http://localhost:5000/api

# Backend USE_FIREBASE_AUTH ke saath align
NEXT_PUBLIC_USE_FIREBASE_AUTH=true

# --- Firebase Web (Console → Project settings → Your apps) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Dev only: Firebase Console test phone numbers + reCAPTCHA skip (fictional numbers only)
# NEXT_PUBLIC_FIREBASE_APP_VERIFICATION_DISABLED=true
# Dev: visible reCAPTCHA widget (recommended on 127.0.0.1)
# NEXT_PUBLIC_FIREBASE_RECAPTCHA_VISIBLE=true

# --- Auth0 SPA (jab NEXT_PUBLIC_USE_FIREBASE_AUTH=false) ---
# Allowed Callback: http://localhost:3000/login
# Agar app LAN/IP se kholte ho, fixed callback do (e.g. http://192.168.31.190:3000/login)
# NEXT_PUBLIC_AUTH0_REDIRECT_URI=http://localhost:3000/login
NEXT_PUBLIC_AUTH0_DOMAIN=
NEXT_PUBLIC_AUTH0_CLIENT_ID=
NEXT_PUBLIC_AUTH0_AUDIENCE=
NEXT_PUBLIC_AUTH0_CONNECTION_GOOGLE=google-oauth2
NEXT_PUBLIC_AUTH0_CONNECTION_APPLE=apple

# --- Stripe (optional — future checkout / Elements; backend STRIPE_* ke saath) ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Optional public IDs ---
# NEXT_PUBLIC_GOOGLE_WEB_CLIENT_ID=
