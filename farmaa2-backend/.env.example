# =============================================================================
# COPY THIS FILE TO `.env` AND FILL VALUES — `.env` is gitignored (do not commit)
# =============================================================================

# --- Server ---
PORT=5000
NODE_ENV=development

# --- CORS (production: comma-separated origins, e.g. https://app.com,https://www.app.com) ---
FRONTEND_URL=http://localhost:3000

# --- MongoDB ---
MONGODB_URI=mongodb://127.0.0.1:27017/furmaa

# --- JWT ---
JWT_SECRET=change-me-min-32-characters-long
JWT_EXPIRE=7d

# --- Auth UI toggle (GET /api/auth/public-config) — match frontend NEXT_PUBLIC_USE_FIREBASE_AUTH ---
USE_FIREBASE_AUTH=true

# --- Auth0 ---
AUTH0_DOMAIN=
AUTH0_AUDIENCE=

# --- Firebase Admin (BACKEND only — verify ID tokens). NOT the same keys as frontend NEXT_PUBLIC_* ---
# Same Firebase project as the web app (project_id / aud must match). Either fill the 3 vars below OR use JSON path.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/furrmaa-65dc3-adminsdk.json

# --- Email (SMTP / OTP) ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=

# --- SMS (optional) ---
MSG91_AUTHKEY=
MSG91_SENDER_ID=VERIFY
MSG91_ROUTE=4
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Razorpay (checkout + subscriptions — code uses this) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- Stripe (optional — use when you integrate Stripe package / routes) ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# --- Cloudinary ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# --- Local upload fallback (optional) ---
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880

# --- Zoho Inventory (optional) ---
ZOHO_INVENTORY_ACCESS_TOKEN=
ZOHO_INVENTORY_CLIENT_ID=
ZOHO_INVENTORY_CLIENT_SECRET=
ZOHO_INVENTORY_REFRESH_TOKEN=
ZOHO_INVENTORY_ORG_ID=
ZOHO_INVENTORY_BASE_URL=https://www.zohoapis.in
ZOHO_ACCOUNTS_URL=https://accounts.zoho.in
ZOHO_AUTO_SYNC_ON_SHIPPED=false
ZOHO_WEBHOOK_SECRET=

# --- Dev / seeded OTP (auth.controller) ---
ADMIN_PHONE=
ADMIN_EMAIL=
ADMIN_OTP=787878

# --- Seed scripts (optional) ---
ADMIN_PASSWORD=
ADMIN_NAME=

# --- OpenAI (AI chat routes) ---
OPENAI_API_KEY=

# --- Misc (e.g. Google OAuth web client id for tooling) ---
# webClientId=
